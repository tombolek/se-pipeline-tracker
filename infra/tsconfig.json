{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "cdk.out/ts",
    "rootDir": ".",
    "declaration": true
  },
  "exclude": ["node_modules", "cdk.out"]
}
