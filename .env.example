# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=se_pipeline
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pipeline_user:changeme@localhost:5432/se_pipeline

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Generate a strong random string for production:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-api-key-here

# ── Client (Vite) ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api/v1

# ── Deploy metadata (injected by deploy.sh from CDK outputs — do not set manually) ──
# DEPLOY_SHA stays for status display.
# FRONTEND_BUCKET / CF_DISTRIBUTION_ID are still written by deploy.sh because the
# script itself uses them for s3 sync + CloudFront invalidation, but the server
# no longer reads them now that the in-app /settings/deploy page is retired.
# GITHUB_TOKEN was only used by the in-app deploy feature and is no longer needed.
FRONTEND_BUCKET=         # auto-injected by deploy.sh (used by deploy.sh, not the server)
CF_DISTRIBUTION_ID=      # auto-injected by deploy.sh (used by deploy.sh, not the server)
DEPLOY_SHA=              # auto-injected by deploy.sh (git HEAD at deploy time)

# ── Static frontend serving (only set on AICrew ECS deploy; leave unset on EC2) ──
# When set to a directory containing the React build (index.html + hashed assets),
# the Express server mounts express.static() + an SPA fallback. On the current
# EC2 deploy (frontend on S3+CloudFront) leave this unset — the server skips the
# middleware and behaves as before.
# CLIENT_DIST_PATH=/app/client/dist
