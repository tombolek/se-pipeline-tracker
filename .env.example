# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=se_pipeline
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pipeline_user:changeme@localhost:5432/se_pipeline

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Generate a strong random string for production:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-api-key-here

# ── Client (Vite) ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api/v1

# ── In-app deploy (injected by deploy.sh from CDK outputs — do not set manually) ──
# GITHUB_TOKEN must be set in .env.prod.local (a classic token with repo:read scope)
GITHUB_TOKEN=your-github-pat-here
FRONTEND_BUCKET=         # auto-injected by deploy.sh
CF_DISTRIBUTION_ID=      # auto-injected by deploy.sh
DEPLOY_SHA=              # auto-injected by deploy.sh (git HEAD at deploy time)
